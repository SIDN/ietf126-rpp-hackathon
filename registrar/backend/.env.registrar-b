# Example env file for a second registrar instance ("Registrar B").
# Copy to .env (or point uvicorn at it) and run on different ports to
# simulate a second registrar transferring domains with the first.
REGISTRAR_NAME=Registrar B
REGISTRY_API_URL=http://localhost:8002/api
CORS_ORIGINS=["http://localhost:5175","http://127.0.0.1:5175"]

# Same Authentik application/provider as Registrar A - reuse its client_id
# and client_secret here, and add this instance's own callback URL
# (http://localhost:8002/api/auth/callback) as an extra redirect URI on
# that provider.
# Note: start.sh overrides these two automatically based on --port /
# --frontend-port; these values only apply when running uvicorn directly.
OAUTH2_ISSUER=http://localhost:9993/application/o/registrar2/
OAUTH2_CLIENT_ID=ssjTZeF8xgNF7tyGZPKxT8AzOBcU67zC8MowiORm
OAUTH2_CLIENT_SECRET=ByNq1pErOndXMoLvZxmiDlJminlhEdVwFqUQhedSmA6OUyiuhsBLPl1lpSy2O21lra2ppcm3nYh8wK6fjkNYtIJVYsMQLxWTeLJMFGMYIZDeOjuDkSU1uVw1WJOu9AYZ

OAUTH2_REDIRECT_URI=http://localhost:8002/api/auth/callback
FRONTEND_URL=http://localhost:5175/
